# Local dev Postgres connection (native install, no Docker — see docs/PHASE_STATUS.md).
# Copy to .env and adjust if needed. .env is gitignored.
#
# PostgreSQL 17 is installed as a portable binary distribution under
# %LOCALAPPDATA%\PostgreSQL\17 (no admin rights, no Windows service).
# Start/stop it with scripts/start_postgres.ps1.
LSB_DB_HOST=localhost
LSB_DB_PORT=5432
LSB_DB_NAME=lsb_dev
LSB_DB_USER=lsb
LSB_DB_PASSWORD=lsb_dev_password

# LSB environment template — copy to .env (never commit the real .env).
# Phase A uses Postgres only; MT5 is unused until Phase B (ADR-001).

# Postgres (playbook §2: database lsb_dev, role lsb)
LSB_DB_HOST=localhost
LSB_DB_PORT=5432
LSB_DB_NAME=lsb_dev
LSB_DB_USER=lsb
LSB_DB_PASSWORD=

# MT5 — Phase B only; leave blank in Phase A.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
